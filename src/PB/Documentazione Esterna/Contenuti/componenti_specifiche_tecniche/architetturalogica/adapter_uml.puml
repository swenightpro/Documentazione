@startuml
skinparam dpi 300
skinparam monochrome false
skinparam classBackgroundColor White/Beige
skinparam classBorderColor Black

class ConversationService {
  +interpret_message(text, ctx): str
  +transcribe_audio(file): str
}

interface IAIClient {
  +interpret_intent(text: str, ctx: list): str
  +transcribe_audio(file: bytes): str
  +generate_embedding(text: str): list
}

class "AsyncOpenAI (SDK)" as AsyncOpenAI {
  +chat.completions.create(model, messages, ...)
  +audio.transcriptions.create(model, file, ...)
  +embeddings.create(model, input, ...)
}

class OpenAIAdapter {
  -_client: AsyncOpenAI
  +interpret_intent(text: str, ctx: list): str
  +transcribe_audio(file: bytes): str
  +generate_embedding(text: str): list
}

ConversationService -> IAIClient
OpenAIAdapter -up-|> IAIClient
OpenAIAdapter -> AsyncOpenAI : adaptee

@enduml