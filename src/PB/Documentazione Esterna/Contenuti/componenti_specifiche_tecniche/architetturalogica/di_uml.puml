@startuml

skinparam monochrome false
skinparam classBackgroundColor White/Beige
skinparam classBorderColor Black
skinparam dpi 300
skinparam componentStyle uml2

class "main.py {Composition Root}" as Main {
  + configure_app(): FastAPI
  + _provide_cart_service(): CartService
  + _provide_auth_service(): AuthService
  + _configure_dependency_overrides(app)
}

class SSEBroadcaster {
  - _subs: dict[int, list[Queue]]
  + subscribe(sid: int): Queue
  + emit(sid, type, data): void
}

class PostgresAdapter {
  - _pool: ConnectionPool
}

class OpenAIAdapter {
  - _client: AsyncOpenAI
}

class CartService {
  + __init__(db: ISessionManager, bc: ISSEBroadcaster)
}

class AuthService {
  + __init__(user_repo: IUserRepository)
}

class ConversationService {
  + __init__(db: ISessionManager, ai: IAIClient, bc: ISSEBroadcaster)
}

class FakeSessionManager {
  - _data: dict
  + get_cart(sid): list
  + update_cart_item(id, qty): void
}

Main ..> PostgresAdapter : <<create>>
Main ..> OpenAIAdapter : <<create>>
Main ..> SSEBroadcaster : <<create>>

Main ..> CartService : injects
Main ..> AuthService : injects
Main ..> ConversationService : injects

PostgresAdapter --> CartService : as ISessionManager
PostgresAdapter --> AuthService : as IUserRepository
'PostgresAdapter ..> ConversationService : injects

FakeSessionManager ..> CartService : replaces in tests

@enduml