@startuml

skinparam monochrome false
skinparam classBackgroundColor White/Beige
skinparam classBorderColor Black
skinparam dpi 300
skinparam componentStyle uml2

class UI {
    + addToCart(qty): void
    + removeFromCart(id): void
    + updateCartQty(id, qty): void
}

class "cartService" as Facade {
    + getCart(sessionId?): Promise<CartItem[]>
    + addItem(codArt, qta, extra?): Promise
    + removeItem(id, sessionId?): Promise
    + updateQty(id, qta, src, sessId?): Promise
}

class "apiFetch()" as ApiFetch {
    + call(path, init): Promise<Response>
}

class "buildApiUrl()" as BuildUrl {
    + build(path: string): string
}

class "getApiBaseUrl()" as BaseUrl {
    + get(): string
}

class "getApiErrorMessage()" as ErrorHandler {
    + get(resp, fallback): Promise<string>
}

UI ..> Facade : <<use>>

Facade -- ApiFetch
Facade -- BuildUrl
Facade -- BaseUrl
Facade -- ErrorHandler

@enduml