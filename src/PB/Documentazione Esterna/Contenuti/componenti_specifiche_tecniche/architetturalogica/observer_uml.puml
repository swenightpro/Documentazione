@startuml
skinparam dpi 300
skinparam monochrome false
skinparam classBackgroundColor White/Beige
skinparam classBorderColor Black

abstract class ISubject {
  +subscribe(in session_id: int, in o: IObserver): Queue
  +unsubscribe(in session_id: int, in o: IObserver): void
  +emit(in session_id: int, in event: dict): void
}

interface IObserver {
  +update(in event: dict): void
}

class SSEBroadcaster {
  -_observers: dict[int, list[IObserver]]
  -_state: dict
  +subscribe(in session_id: int, in o: IObserver): Queue
  +unsubscribe(in session_id: int, in o: IObserver): void
  +emit(in session_id: int, in event: dict): void
  +get_state(): dict
}

class SSEClientQueue {
  -_queue: asyncio.Queue
  +update(in event: dict): void
}

class CartService {
  +add_item(cmd: CartItemCommand): void
}

ISubject -> IObserver : observers
SSEBroadcaster -up-|> ISubject
SSEClientQueue .up.|> IObserver
CartService .up.> SSEBroadcaster : <<use>>

@enduml