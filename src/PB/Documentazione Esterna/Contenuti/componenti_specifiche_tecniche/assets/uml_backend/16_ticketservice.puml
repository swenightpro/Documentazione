@startuml
skinparam dpi 300
skinparam shadowing false
skinparam backgroundColor White
skinparam defaultFontName Helvetica
skinparam defaultFontSize 12
skinparam ArrowColor #4B5563
skinparam ArrowThickness 1
skinparam roundcorner 8
skinparam class {
  BackgroundColor #F9FAFB
  BorderColor #4B5563
  FontColor #111827
  AttributeFontColor #374151
  StereotypeFontColor #6B7280
}
skinparam classAttributeIconSize 0

class "TicketService" as C1 {
  + create_ticket(session_id: int, cod_cli: int)
  + get_open_tickets()
  + get_ticket_by_id(ticket_id: int)
  + get_ticket_by_session(session_id, cod_cli)
  + lock_ticket(ticket_id, operator_id)
  + unlock_ticket(ticket_id)
  + close_ticket(ticket_id, closed_by)
  + close_ticket_by_session(session_id, closed_by, cod_cli)
  + send_chat_message(ticket_id, content)
  + save_customer_message(session_id, content)
  + get_platform_usage_overview(days)
}
@enduml
