@startuml
skinparam dpi 300
skinparam shadowing false
skinparam backgroundColor White
skinparam defaultFontName Helvetica
skinparam defaultFontSize 12
skinparam ArrowColor #4B5563
skinparam ArrowThickness 1
skinparam roundcorner 8
skinparam class {
  BackgroundColor #F9FAFB
  BorderColor #4B5563
  FontColor #111827
  AttributeFontColor #374151
  StereotypeFontColor #6B7280
}
skinparam classAttributeIconSize 0

interface "ISessionManager" as C1 {
  + get_active_session(user_id: int)
  + create_session(user_id: int)
  + get_messages(session_id: int)
  + save_message(session_id, sender, content, metadata)
  + get_cart_by_session(session_id: int)
  + get_cart(user_id: int)
  + add_to_cart(user_id, cod_art, qta, source, ...)
  + add_to_cart_by_session(session_id, cod_art, qta, source, ...)
  + remove_from_cart(cart_item_id, user_id)
  + remove_from_cart_by_session(cart_item_id, session_id)
  + update_cart_quantity(cart_item_id, user_id, qta, source)
  + update_cart_quantity_by_session(cart_item_id, session_id, qta, source)
  + clear_cart(user_id)
  + clear_cart_by_session(session_id)
}
@enduml
