@startuml
skinparam dpi 300
skinparam shadowing false
skinparam backgroundColor White
skinparam defaultFontName Helvetica
skinparam defaultFontSize 12
skinparam ArrowColor #4B5563
skinparam ArrowThickness 1
skinparam roundcorner 8
skinparam class {
  BackgroundColor #F9FAFB
  BorderColor #4B5563
  FontColor #111827
  AttributeFontColor #374151
  StereotypeFontColor #6B7280
}
skinparam classAttributeIconSize 0

class "cartService" as C1 {
  + getCart(sessionId?)
  + addItem(codArt, qta, extra?)
  + removeItem(id, sessionId?)
  + updateQty(id, qta, source, sessionId?)
  + addByName(productName, qta, sessionId?)
  + addByCode(codArt, qta, sessionId?)
}
@enduml
