@startuml
skinparam dpi 300
skinparam shadowing false
skinparam backgroundColor White
skinparam defaultFontName Helvetica
skinparam defaultFontSize 12
skinparam ArrowColor #4B5563
skinparam ArrowThickness 1
skinparam roundcorner 8
skinparam class {
  BackgroundColor #F9FAFB
  BorderColor #4B5563
  FontColor #111827
  AttributeFontColor #374151
  StereotypeFontColor #6B7280
}
skinparam classAttributeIconSize 0

class "ticketService" as C1 {
  + getOpenTickets()
  + getTicketDetail(ticketId)
  + getPlatformUsageOverview(days)
  + lockTicket(ticketId)
  + unlockTicket(ticketId)
  + closeTicket(ticketId)
  + openTicket(sessionId)
  + getTicketBySession(sessionId)
  + closeTicketBySession(sessionId)
  + sendChatMessage(ticketId, content)
  + sendCustomerMessage(sessionId, content)
}
@enduml
